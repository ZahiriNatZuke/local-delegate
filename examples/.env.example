# local-delegate — variables de entorno (copia a .env y ajusta). NO subas tu .env real.

# --- Endpoint OpenAI-compatible ---
LOCAL_DELEGATE_BASE_URL=http://127.0.0.1:9292/v1
# LOCAL_DELEGATE_API_KEY=          # solo si tu endpoint exige un token
# LOCAL_DELEGATE_TIMEOUT=180

# --- Catálogo de modelos (ids según tu backend) ---
# LOCAL_DELEGATE_MODEL_MECHANICAL=gemma3-4b
# LOCAL_DELEGATE_MODEL_LONG=llama31-8b
# LOCAL_DELEGATE_MODEL_CODE=qwen25-coder-14b
# LOCAL_DELEGATE_MODEL_FAST=qwen35-2b

# --- Web de métricas ---
# LOCAL_DELEGATE_WEB=1
# LOCAL_DELEGATE_WEB_PORT=9393

# --- Log de uso (default: dir de datos de usuario) ---
# LOCAL_DELEGATE_LOG=/ruta/a/usage.jsonl

# --- Auto-arranque de llama-swap (opt-in) ---
# LOCAL_DELEGATE_AUTOSTART=0
# LLAMASWAP_EXE=llama-swap
# LLAMASWAP_CONFIG=/ruta/a/llama-swap/config.yaml
# LLAMASWAP_LISTEN=127.0.0.1:9292
